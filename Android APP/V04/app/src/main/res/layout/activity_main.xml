<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌉"
                android:textSize="44sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRIDGE MONITOR"
                android:textColor="#E0F2FF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EC6020 Smart Safety Monitoring System"
                android:textColor="#4A7A9B"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- STATUS BANNER -->
        <LinearLayout
            android:id="@+id/layoutStatusBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="14dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="#1C2833">

            <TextView
                android:id="@+id/tvStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡  Not Connected"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ALERT BOX (hidden until WARNING/DANGER) -->
        <TextView
            android:id="@+id/tvAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="10dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="#7B0000"
            android:visibility="gone"/>

        <!-- SENSOR CARDS ROW 1: Water + Weight -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <!-- Water Level Card -->
            <LinearLayout
                android:id="@+id/layoutWaterCard"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="#0D1B24">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧"
                    android:textSize="26sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WATER LEVEL"
                    android:textColor="#3A6A8A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvWater"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- cm"
                    android:textColor="#00E676"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Weight Card -->
            <LinearLayout
                android:id="@+id/layoutWeightCard"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="#0D1B24">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚖️"
                    android:textSize="26sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STRAIN LOAD"
                    android:textColor="#3A6A8A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- g"
                    android:textColor="#00E676"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- SENSOR CARD: Tilt -->
        <LinearLayout
            android:id="@+id/layoutTiltCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="#0D1B24">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📐"
                android:textSize="28sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STRUCTURAL TILT / VIBRATION"
                    android:textColor="#3A6A8A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvTilt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#00E676"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- THRESHOLDS REFERENCE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="#060F18">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAFETY THRESHOLDS"
                android:textColor="#2E5F7A"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢  SAFE      Water > 100 cm  |  Load &lt; 1000 g"
                android:textColor="#4A8A6A"
                android:textSize="11sp"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟡  WARNING   Water 75–100 cm | Load 1000–1500 g"
                android:textColor="#8A7A2A"
                android:textSize="11sp"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴  DANGER    Water &lt; 75 cm   | Load > 1500 g  | Tilt"
                android:textColor="#8A3A3A"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- BLUETOOTH CONNECTION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="#0D1B24">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLUETOOTH  ·  HC-05"
                android:textColor="#2E5F7A"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not connected"
                android:textColor="#607D8B"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="📡 CONNECT"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#0D47A1"
                    android:layout_marginEnd="8dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnDisconnect"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="✖ DISCONNECT"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#7B0000"
                    android:enabled="false"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
        </LinearLayout>

        <!-- RAW DATA DEBUG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="#04090F">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAW DATA"
                android:textColor="#1E3A4A"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvRawData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for data..."
                android:textColor="#1A5C2A"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
